# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sariel-dev

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DSN=postgresql+asyncpg://sariel:sariel-dev@localhost:5432/sariel

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=900

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/SarielReadOnly   # for cross-account

# ── Azure ─────────────────────────────────────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_SUBSCRIPTION_ID=your-subscription-id

# ── LLM explainer (optional) ─────────────────────────────────────────────────
LLM_PROVIDER=anthropic    # anthropic | openai | none
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── S3 raw snapshot storage (optional) ───────────────────────────────────────
# RAW_BUCKET=sariel-raw-snapshots

# On Prem
# ONPREM_ACCOUNT_ID=olmec-onprem

MANAGEENGINE_BASE_URL=https://your-manageengine-host
MANAGEENGINE_AUTH_HEADER=Zoho-oauthtoken ROTATED_TOKEN_GOES_HERE
MANAGEENGINE_VERIFY_SSL=true

SOLARWINDS_BASE_URL=https://your-solarwinds-host:17778
SOLARWINDS_USERNAME=sariel
SOLARWINDS_PASSWORD=replace_me
SOLARWINDS_VERIFY_SSL=false

# ── Risk scoring thresholds ───────────────────────────────────────────────────
SCORE_CRITICAL_THRESHOLD=70.0
SCORE_HIGH_THRESHOLD=40.0
SCORE_SUPPRESS_BELOW=10.0

# ── API auth ──────────────────────────────────────────────────────────────────
# Comma-separated list. Leave empty for dev mode (no key required).
# API_KEYS=key1,key2

# ── Scheduler ─────────────────────────────────────────────────────────────────
POLL_INTERVAL_HOURS=6
IDENTITY_POLL_INTERVAL_HOURS=1
