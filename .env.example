# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sariel-dev

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DSN=postgresql+asyncpg://sariel:sariel-dev@localhost:5432/sariel

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=900

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/SarielReadOnly   # for cross-account

# ── Azure ─────────────────────────────────────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_SUBSCRIPTION_ID=your-subscription-id

# ── LLM explainer (optional) ─────────────────────────────────────────────────
LLM_PROVIDER=anthropic    # anthropic | openai | none
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── S3 raw snapshot storage (optional) ───────────────────────────────────────
# RAW_BUCKET=sariel-raw-snapshots

# On Prem
# ONPREM_ACCOUNT_ID=olmec-onprem

# MANAGE ENGINE EPC
MANAGEENGINE_BASE_URL=https://your-manageengine-host
MANAGEENGINE_AUTH_HEADER=Zoho-oauthtoken ROTATED_TOKEN_GOES_HERE
MANAGEENGINE_VERIFY_SSL=true

# SOLARWINDS
SOLARWINDS_BASE_URL=https://your-solarwinds-host:17778
SOLARWINDS_USERNAME=sariel
SOLARWINDS_PASSWORD=replace_me
SOLARWINDS_VERIFY_SSL=false

# NESSUS
NESSUS_BASE_URL=https://your-nessus-url/
NESSUS_ACCESS_KEY=replace_with_access_key
NESSUS_SECRET_KEY=replace_with_secret_key

# DNS
DNS_HOSTNAMES=host1.domain.local,host2.domain.local
DNS_REVERSE_CIDRS=10.100.250.0/24,10.100.15.0/24

# Active Directory
AD_SERVER_URI=ldaps://dc01.yourdomain.local:636
AD_BIND_USER=YOURDOMAIN\sariel
AD_BIND_PASSWORD=replace_me
AD_BASE_DN=DC=yourdomain,DC=local
AD_USE_SSL=true

# FORTINET
FORTINET_VERIFY_SSL=false

FORTINET_FG_EDGE_01_URL=https://fg-edge-01.yourdomain.local
FORTINET_FG_EDGE_01_TOKEN=replace_me
FORTINET_FG_EDGE_01_VDOM=root

FORTINET_FG_SEG_01_URL=https://fg-seg-01.yourdomain.local
FORTINET_FG_SEG_01_TOKEN=replace_me
FORTINET_FG_SEG_01_VDOM=root

FORTINET_FG_DMZ_01_URL=https://fg-dmz-01.yourdomain.local
FORTINET_FG_DMZ_01_TOKEN=replace_me
FORTINET_FG_DMZ_01_VDOM=root

# ── Risk scoring thresholds ───────────────────────────────────────────────────
SCORE_CRITICAL_THRESHOLD=70.0
SCORE_HIGH_THRESHOLD=40.0
SCORE_SUPPRESS_BELOW=10.0

# ── API auth ──────────────────────────────────────────────────────────────────
# Comma-separated list. Leave empty for dev mode (no key required).
# API_KEYS=key1,key2

# ── Scheduler ─────────────────────────────────────────────────────────────────
POLL_INTERVAL_HOURS=6
IDENTITY_POLL_INTERVAL_HOURS=1

# ── OPENAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
SARIEL_AI_MODEL=gpt-5.5-thinking
SARIEL_AI_MAX_HOPS=4
SARIEL_AI_WRITE_SUGGESTIONS=false